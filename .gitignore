# Local runtime data under data/ is ignored (SQLite DBs, Milvus Lite files,
# checkpoints), EXCEPT the RAG corpus (knowledge-base content) and the package
# marker, which are version-controlled. New corpus files are tracked
# automatically — no force-add needed.
/data/*
!/data/__init__.py
!/data/rag_corpus/

__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
logs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.DS_Store
*.swp
node_modules/
.idea/
