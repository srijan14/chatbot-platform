# =============================================================================
# Chatbot platform — environment config
#
# Copy to `.env` (gitignored) and fill in. This file holds ONLY the chatbot
# platform's own infra + secrets (Azure, databases, vector store, logging) —
# things that are deployment-wide and shared across every bot.
#
# Per-bot behaviour (which skills a bot uses, its RAG corpus/collection,
# persona) lives in the bot YAML under configs/bots/, NOT here.
# =============================================================================

# --- Azure OpenAI (chat) --------------------------------------------------
# From the Azure portal: open your Azure OpenAI resource → "Keys and Endpoint".
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
# For o-series reasoning deployments (o4-mini etc.) with tool calling,
# use 2025-01-01-preview or later. 2024-10-21 is the most recent GA and
# works for non-reasoning deployments.
AZURE_OPENAI_API_VERSION=2025-01-01-preview
# The deployment name you set in Azure AI Foundry → Deployments. If unset, the value
# in the bot YAML (`llm.deployment`, e.g. configs/bots/am_marketplace.yaml) is used.
AZURE_OPENAI_DEPLOYMENT=o4-mini

# --- Azure OpenAI (embeddings, separate resource) -------------------------
# Azure allows only one model family per resource, so the embedding model
# usually lives on its OWN resource with its OWN endpoint + key. These take
# precedence; if left blank the embedder falls back to the chat resource above.
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://YOUR-EMBEDDING-RESOURCE.openai.azure.com/
AZURE_OPENAI_EMBEDDING_API_KEY=
# Optional — defaults to AZURE_OPENAI_API_VERSION when unset.
# AZURE_OPENAI_EMBEDDING_API_VERSION=2024-10-21
# Deployment name of the embedding model (used directly as the model name on
# the wire). Must be a text-embedding-3-small deployment (1536 dims) — the RAG
# engine pins dimensions per collection, so changing the model means creating a
# new collection.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Chatbot persistence (Postgres) ---------------------------------------
# Relational plane: sessions, messages, turn_logs. Two driver conventions live
# below — keep them straight:
#   * SQLAlchemy stores use the asyncpg driver  → postgresql+asyncpg://...
#   * the LangGraph checkpointer uses psycopg    → postgresql://...        (no +driver)
# The docker-compose.yml in this repo brings up a matching Postgres
# (user/pass/db all "chatbot") on localhost:5432.
CHATBOT_DB_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot
# LangGraph conversation-state checkpointer. Plain libpq DSN (psycopg), NOT the
# +asyncpg form. Leave unset to fall back to a local SQLite file
# (CHATBOT_CHECKPOINT_DB, default data/chatbot_checkpoints.db).
CHATBOT_CHECKPOINT_DB_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot
# Zero-infra fallback (no Docker): comment the three Postgres lines above and
# uncomment these to run everything on local SQLite files instead.
# CHATBOT_DB_URL=sqlite+aiosqlite:///data/chatbot.db
# CHATBOT_CHECKPOINT_DB=data/chatbot_checkpoints.db

# --- RAG (in-process) -----------------------------------------------------
# RAG runs inside the chatbot process (no separate services). The chatbot
# builds one RagEngine and gives each bot its own collection ({bot_id}__{name}).
# Async SQLAlchemy URL for the RAG control plane (collections, jobs, dedupe).
# Shares the same Postgres instance as the chatbot DB (no table-name overlap).
RAG_DB_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5432/chatbot
# RAG_DB_URL=sqlite+aiosqlite:///data/rag.db   # zero-infra fallback
# Vector store (Milvus). Point this at the local Milvus server from
# docker-compose. For a zero-infra run, set it to a file path (e.g.
# ./data/milvus.db) and pymilvus runs Milvus Lite embedded — no server needed.
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
# --- Document blob storage (original uploaded files / upserted text) ---------
# Backend for storing the original document artifacts: "local" (filesystem,
# zero-infra default) or "s3" (MinIO / any S3-compatible store, returns
# presigned download links). Everything below only applies when =s3.
RAG_BLOB_BACKEND=local
# Filesystem dir used when RAG_BLOB_BACKEND=local.
RAG_BLOB_DIR=data/blobs
# S3/MinIO settings (used when RAG_BLOB_BACKEND=s3). Defaults match the MinIO in
# docker-compose (ports published to the host). Use a bucket dedicated to RAG
# documents — separate from Milvus's internal storage.
RAG_S3_ENDPOINT=http://localhost:9000
RAG_S3_ACCESS_KEY=minioadmin
RAG_S3_SECRET_KEY=minioadmin
RAG_S3_BUCKET=rag-documents
RAG_S3_REGION=us-east-1
# Host that presigned links should point at, when it differs from the endpoint
# the service uses internally (e.g. service reaches "minio:9000" over the compose
# network, but partners must use a public host). Leave blank to sign against
# RAG_S3_ENDPOINT.
RAG_S3_PUBLIC_ENDPOINT=
# Presigned link lifetime in seconds (default 1 hour).
RAG_S3_URL_EXPIRY=3600
# LLM-assisted chunking (optional). When enabled, an extra single LLM call
# inspects each incoming document and picks the chunking strategy + size/overlap
# (markdown vs. recursive) instead of routing purely on MIME type. Off by
# default — unset/false keeps the mime-dispatching AutoChunker. Markdown and
# short docs skip the call; any planner error falls back to AutoChunker.
RAG_LLM_CHUNKING=false
# Deployment used for the chunk-planner call. Picking a chunking strategy is a
# structured classification, not a reasoning task — a fast mid-tier model is the
# best fit. Defaults to "gpt-4o-mini" when unset (NOT the bot's main model,
# which may be a slow reasoning deployment). Set this to your Azure deployment
# name if it differs from "gpt-4o-mini".
AZURE_OPENAI_CHUNKING_DEPLOYMENT=gpt-4o-mini
# Per-bot API keys. Each bot's YAML (configs/bots/<bot>.yaml) lists the keys it
# accepts under `auth.api_keys`, referencing env vars like ${AM_MARKETPLACE_API_KEY}
# so real secrets stay out of the committed config. Leave unset to keep that bot
# open (no auth) for local/dev; set it to require `X-API-Key` on that bot's
# document + chat endpoints. Give each channel partner its own value.
AM_MARKETPLACE_API_KEY=
# Optional connector credentials (only needed if you enable those sources)
CONFLUENCE_BASE_URL=
CONFLUENCE_USER_EMAIL=
CONFLUENCE_API_TOKEN=
NOTION_API_TOKEN=

# --- Observability --------------------------------------------------------
LOG_DIR=logs
# Set to 1 to mirror every turn into logs/turns.jsonl in addition to the DB.
LOG_JSONL=0
# Pipeline log verbosity. DEBUG shows every intermediate payload (assistant
# message JSON, tool-call placeholders, MCP cache hits). INFO is the default
# and shows one line per stage transition. WARNING quiets it down.
#
# Clarification-specific lines (all at INFO) you'll see when this skill fires:
#   chatbot.clarification [clar] SCHEMA-BUILT          (once per skill prep)
#   chatbot.clarification [clar] CALL-RECEIVED         (model invoked the tool)
#   chatbot.clarification [clar] SIGNAL-EMITTED        (terminal signal returned)
#   chatbot.orch          [orch] SIGNAL-COLLECTED      (orchestrator picked it up)
#   chatbot.orch          [orch] CLARIFICATION-CONTINUATION  (next turn answers it)
# Set LOG_LEVEL=DEBUG additionally to dump full assistant payloads.
LOG_LEVEL=INFO
