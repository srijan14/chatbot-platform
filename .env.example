# --- Azure OpenAI ---------------------------------------------------------
# From the Azure portal: open your Azure OpenAI resource → "Keys and Endpoint".
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
# 2024-10-21 is GA and supports function (tool) calling. Newer preview versions also work.
AZURE_OPENAI_API_VERSION=2024-10-21
# The deployment name you set in Azure AI Foundry → Deployments. If unset, the value
# in configs/bots/telecom_support.yaml (`llm.deployment`) is used as a fallback.
AZURE_OPENAI_DEPLOYMENT=o4-mini

# --- Local services -------------------------------------------------------
TELECOM_API_URL=http://localhost:8001
MCP_TELECOM_URL=http://localhost:8765/mcp
TELECOM_DB_PATH=data/telecom.db
LOG_DIR=logs
