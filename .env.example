# --- Azure OpenAI ---------------------------------------------------------
# From the Azure portal: open your Azure OpenAI resource → "Keys and Endpoint".
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
# 2024-10-21 is GA and supports function (tool) calling. Newer preview versions also work.
AZURE_OPENAI_API_VERSION=2024-10-21
# The deployment name you set in Azure AI Foundry → Deployments. If unset, the value
# in configs/bots/telecom_support.yaml (`llm.deployment`) is used as a fallback.
AZURE_OPENAI_DEPLOYMENT=o4-mini
# Deployment name of the embedding model. Must be an Azure deployment of
# text-embedding-3-small (1536 dims) — the RAG engine pins the dimensions per
# collection, so changing the model means creating a new collection.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Local services -------------------------------------------------------
TELECOM_API_URL=http://localhost:8001
MCP_TELECOM_URL=http://localhost:8765/mcp
TELECOM_DB_PATH=services/telecom_api/data/telecom.db

# --- RAG platform ---------------------------------------------------------
RAG_API_HOST=127.0.0.1
RAG_API_PORT=8002
RAG_MCP_HOST=127.0.0.1
RAG_MCP_PORT=8766
RAG_API_URL=http://localhost:8002
RAG_MCP_URL=http://localhost:8766/mcp
RAG_DB_URL=sqlite+aiosqlite:///data/rag.db
RAG_CHROMA_PATH=./data/chroma
RAG_UPLOAD_DIR=./data/rag_uploads
# Tenant id the rag_mcp server injects as the X-Tenant-Id header on every
# rag_api call. The downstream bot's RagSkill points at this MCP server.
RAG_TENANT_ID=telecom_demo
# Optional connector credentials (only needed if you enable those sources)
CONFLUENCE_BASE_URL=
CONFLUENCE_USER_EMAIL=
CONFLUENCE_API_TOKEN=
NOTION_API_TOKEN=

# --- Chatbot persistence --------------------------------------------------
# Async SQLAlchemy URL for the chatbot's own DB (sessions, messages, turn_logs).
CHATBOT_DB_URL=sqlite+aiosqlite:///data/chatbot.db

# --- Observability --------------------------------------------------------
LOG_DIR=logs
# Set to 1 to mirror every turn into logs/turns.jsonl in addition to the DB.
LOG_JSONL=0
# Pipeline log verbosity. DEBUG shows every intermediate payload (assistant
# message JSON, tool-call placeholders, MCP cache hits). INFO is the default
# and shows one line per stage transition. WARNING quiets it down.
#
# Clarification-specific lines (all at INFO) you'll see when this skill fires:
#   chatbot.clarification [clar] SCHEMA-BUILT          (once per skill prep)
#   chatbot.clarification [clar] CALL-RECEIVED         (model invoked the tool)
#   chatbot.clarification [clar] SIGNAL-EMITTED        (terminal signal returned)
#   chatbot.orch          [orch] SIGNAL-COLLECTED      (orchestrator picked it up)
#   chatbot.orch          [orch] CLARIFICATION-CONTINUATION  (next turn answers it)
# Set LOG_LEVEL=DEBUG additionally to dump full assistant payloads.
LOG_LEVEL=INFO
