# telecom_api — mock telecom REST backend (demo service, port 8001)
#
# Copy to services/telecom_api/.env if you need to override the defaults below.
# The code falls back to these same defaults when unset, so the honcho demo
# runs without an .env at all.

# SQLite file backing the mock telecom data (created/seeded by seed.py).
TELECOM_DB_PATH=services/telecom_api/data/telecom.db
