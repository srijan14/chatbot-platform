# mcp_telecom — MCP server wrapping the telecom REST API as tools (demo service, port 8765)
#
# Copy to services/mcp_telecom/.env if you need to override the default below.
# The code falls back to this same default when unset, so the honcho demo runs
# without an .env at all.
#
# NOTE: the chatbot does NOT read this. The bot reaches this MCP server via the
# URL in its YAML (configs/bots/telecom_support.yaml → tool_call.mcp_servers).
# This var is only how THIS service finds the telecom REST API it wraps.

# Base URL of the telecom_api service this MCP server proxies.
TELECOM_API_URL=http://localhost:8001
